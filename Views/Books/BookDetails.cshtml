@model OopProject.Models.Book
@{
    ViewData["Title"] = Model?.BookTitle ?? "Book Details";

    // Kunin ang image path; gumamit ng default asset kung walang nakitang upload [cite: 172]
    var imagePath = string.IsNullOrEmpty(Model?.Image)
        ? Url.Content("~/images/books/default.png")
        : Model.Image;
}
<partial name="/Views/Shared/_Header.cshtml" />

<section class="py-5 bg-bubble-light content-spacer">
    <div class="container py-4">
        <div class="row g-4 justify-content-center">

            <div class="col-md-5 col-lg-3" data-aos="zoom-in" data-aos-duration="800">
                <div class="card border-0 shadow-sm rounded-5 overflow-hidden bg-white p-3 h-100 text-center transition-bubble">
                    <div class="book-details-cover-container rounded-4 overflow-hidden position-relative h-100">
                        <img src="@imagePath" alt="@Model?.BookTitle" class="img-fluid w-100 h-100 object-fit-cover book-details-img">
                    </div>
                </div>
            </div>

            <div class="col-md-7 col-lg-5" data-aos="fade-up" data-aos-duration="800">
                <div class="card border-0 shadow-sm rounded-5 bg-white p-4 p-md-5 h-100 transition-bubble">

                    <div class="border-bottom pb-3 mb-4">
                        <span class="badge bg-info text-dark rounded-pill px-3 py-2 mb-2 fw-bold">Central Repository</span>
                        <h2 class="fw-extrabold text-dark tracking-tight mb-0">@Model?.BookTitle</h2>
                        <p class="text-muted small mt-1 mb-0">By <span class="fw-bold text-secondary">@Model?.Author</span></p>
                    </div>

                    <div class="mb-4">
                        <h5 class="fw-bold text-primary mb-2 d-flex align-items-center gap-2">
                            <i class="fa-solid fa-book-open"></i> About the Book
                        </h5>
                        <p class="text-muted leading-relaxed text-justify small mb-0">
                            @Model?.BookDescription
                        </p>
                    </div>

                    <div>
                        <h5 class="fw-bold text-primary mb-2 d-flex align-items-center gap-2">
                            <i class="fa-solid fa-feather-pointed"></i> About the Author
                        </h5>
                        <p class="text-muted leading-relaxed text-justify small mb-0">
                            @Model?.AuthorDescription
                        </p>
                    </div>

                </div>
            </div>

            <div class="col-md-12 col-lg-4" data-aos="fade-up" data-aos-duration="800" data-aos-delay="100">
                <div class="card border-0 shadow-lg rounded-5 bg-white overflow-hidden p-4 p-sm-5 transition-bubble sticky-lg-top-bubble">

                    <div class="text-center mb-4">
                        <div class="icon-bubble bg-warning text-dark mx-auto mb-3 fs-4 shadow-sm">
                            <i class="fa-solid fa-heart-circle-plus"></i>
                        </div>
                        <h3 class="fw-extrabold text-dark mb-1">Want to Read?</h3>
                        <p class="text-muted small">Submit a completely zero-cost digital copy loan request</p>
                    </div>

                    <form asp-controller="Books" asp-action="RequestBooks" method="post">
                        <input type="hidden" name="bookId" value="@Model?.Id" />

                        <div class="row g-3">

                            <div class="col-12">
                                <div class="form-group">
                                    <label class="form-label fw-semibold text-secondary small" for="name">Full Name</label>
                                    <input type="text" id="name" name="name" class="form-control rounded-3" placeholder="Enter your full name" required>
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="form-group">
                                    <label class="form-label fw-semibold text-secondary small" for="email">Email Address</label>
                                    <input type="email" id="email" name="email" class="form-control rounded-3" placeholder="example@@email.com" required>
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="form-group">
                                    <label class="form-label fw-semibold text-secondary small" for="phone_number">Phone Number</label>
                                    <input type="text" id="phone_number" name="phone_number" class="form-control rounded-3" placeholder="09XXXXXXXXX" required>
                                </div>
                            </div>

                            <div class="col-12 pt-3">
                                <button type="submit" class="btn btn-primary w-100 rounded-pill py-3 fw-bold text-white shadow-sm transition-bubble">
                                    <i class="fa-solid fa-paper-plane me-2"></i> Send Book Request
                                </button>
                            </div>

                        </div>
                    </form>

                </div>
            </div>

        </div>
    </div>
</section>

<partial name="/Views/Shared/_Footer.cshtml" />