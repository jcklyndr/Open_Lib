@model OopProject.Models.Book
@{
    ViewData["Title"] = Model?.BookTitle ?? "Book Details";
}
<partial name="/Views/Shared/_Header.cshtml" />
<br>
<body class="bg-light">
<div class="maincontainerbook">
    <div class="col-md-7 order-md-1 pr-4 mr-5 ftco-animate book-description">
        <div class="heading-section">
            <div class="pl-md-4">
                <h2 class="text-brown text-left">@Model.BookTitle</h2>
            </div>
        </div>
        <div class="text-justify booksdetail-body-custom">
            <div class="media-body pl-3">
                <h3 class="heading text-brown">Description about the book</h3>
                <p>@Model.BookDescription</p>
            </div>

            <div class="media-body pl-3">
                <h3 class="heading text-brown">Details about the Author</h3>
                <p>@Model.AuthorDescription</p>
            </div>
        </div>
    </div>

    <div class="col-md-4 order-md-1 pr-4 ftco-animate book-form">
        <!-- book-form -->
        <section class="ftco-section ftco-book ftco-no-pt ftco-no-pb">
            <form asp-controller="Books" asp-action="RequestBooks" method="post">
                <h2 class="formheading-section pl-3 pb-3">Want to Read?</h2>

                <input type="hidden" name="bookId" value="@Model.Id" />

                <div class="col-md-12">
                    <div class="form-group">
                        <input type="text" name="name" class="form-control-custom" placeholder="Name" required>
                    </div>
                </div>

                <div class="col-md-12">
                    <div class="form-group">
                        <input type="text" name="email" class="form-control-custom" placeholder="Email" required>
                    </div>
                </div>

                <div class="col-md-12">
                    <div class="form-group">
                        <input type="text" name="phone_number" class="form-control-custom" placeholder="Phone Number" required>
                    </div>
                </div>

                <div class="col-md-12">
                    <div class="">
                        <button type="submit" class="btn btn-custom py-3 px-4">Request</button>
                    </div>
                </div>
            </form>
        </section>
    </div>
</div>
</body>
<partial name="/Views/Shared/_Footer.cshtml" />
