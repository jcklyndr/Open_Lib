@model OopProject.Models.Book

@{
    ViewBag.Title = "Add Book";
}

<partial name="/Views/Shared/_HeaderAdmin.cshtml"></partial>

<div class="row AddBooks mx-auto">
    <div class="col">
        <div class="card">
            <div class="card-body">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success">
                        @TempData["SuccessMessage"]
                    </div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger">
                        @TempData["ErrorMessage"]
                    </div>
                }

                <h5 class="card-title mb-5 d-inline">Add Book</h5>
                <form method="POST" asp-action="AddBooks" asp-controller="BooksAdmin" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="form-group">
                        <label asp-for="BookTitle"></label>
                        <input asp-for="BookTitle" class="form-control" required />
                    </div>

                    <div class="form-group">
                        <label asp-for="PublicationYear"></label>
                        <input asp-for="PublicationYear" class="form-control" required />
                    </div>

                    <div class="form-group">
                        <label asp-for="BookDescription"></label>
                        <textarea asp-for="BookDescription" class="form-control" required></textarea>
                    </div>

                    <div class="form-group">
                        <label for="Image">Image (optional)</label>
                        <input asp-for="Image" type="file" class="form-control" required />
                    </div>

                    <div class="form-group">
                        <label asp-for="Author"></label>
                        <input asp-for="Author" class="form-control" required />
                    </div>

                    <div class="form-group">
                        <label asp-for="AuthorDescription"></label>
                        <textarea asp-for="AuthorDescription" class="form-control"></textarea>
                    </div>
                    <div class="form-group">
                        <label for="Categories">Select Categories</label>
                        <div id="Categories">
                            @foreach (var category in ViewBag.Categories)
                            {
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" name="selectedCategoryIds" value="@category.Id" id="category_@category.Id">
                                    <label class="form-check-label" for="category_@category.Id">@category.CategoryName</label>
                                </div>
                            }
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary">Add Book</button>
                </form>
            </div>
        </div>
    </div>
</div>
