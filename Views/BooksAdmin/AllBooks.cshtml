
@{
    ViewData["Title"] = "All Books";
}
<partial name="/Views/Shared/_HeaderAdmin.cshtml"></partial>

<div class="row">
  <div class="col">
    <div class="card">
      <div class="card-body">
        <h5 class="card-title mb-4 d-inline">All Books Available</h5>
       <a  asp-controller="BooksAdmin" asp-action="AddBooks" class="btn btn-custom mb-4 text-center float-right">Add Books</a>
        <table class="table mt-5">
          <thead>
            <tr>
              <th scope="col">#</th>
              <th scope="col">Name</th>
              <th scope="col">Category</th>
              <th scope="col">Publication year</th>
              <th scope="col">description</th>
              <th scope="col">image</th>
              <th scope="col">author</th>
              <th scope="col">authordescription</th>

            </tr>
          </thead>
          <tbody>

            <!--Foreach dito-->

            <tr>
              <th scope="row">books->id</th>
              <td>books->name</td>
              <td>books->categoryid</td>
              <td>books->publication year</td>
              <td>books->description</td>
              <td>books->image</td>
              <td>books->author</td>
              <td>books->authordescription</td>
                            <td><a href="" class="btn btn-danger  text-center " onclick="return confirm('Are you sure you want to delete this Category?');">Delete</a></td>
            </tr>
            <!--End of foreach-->
          </tbody>
        </table> 
      </div>
    </div>
  </div>
</div>