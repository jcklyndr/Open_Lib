@model OopProject.Models.Book

@{
    ViewBag.Title = "Update Book";
}

<partial name="/Views/Shared/_HeaderAdmin.cshtml"></partial>

<div class="row UpdateBooks mx-auto">
    <div class="col">
        <div class="card">
            <div class="card-body">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success">
                        @TempData["SuccessMessage"]
                    </div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger">
                        @TempData["ErrorMessage"]
                    </div>
                }

                <h5 class="card-title mb-5 d-inline">Update Book</h5>
                <form method="POST" asp-action="UpdateBooks" asp-controller="BooksAdmin" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="form-group">
                        <label asp-for="BookTitle"></label>
                        <input asp-for="BookTitle" class="form-control" />
                        <span asp-validation-for="BookTitle" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="PublicationYear"></label>
                        <input asp-for="PublicationYear" class="form-control" />
                        <span asp-validation-for="PublicationYear" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="BookDescription"></label>
                        <textarea asp-for="BookDescription" class="form-control"></textarea>
                        <span asp-validation-for="BookDescription" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label for="Image">Image (optional)</label>
                        <input type="file" name="image" id="image" class="form-control" />
                    </div>

                    <div class="form-group">
                        <label asp-for="Author"></label>
                        <input asp-for="Author" class="form-control" />
                        <span asp-validation-for="Author" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="AuthorDescription"></label>
                        <textarea asp-for="AuthorDescription" class="form-control"></textarea>
                        <span asp-validation-for="AuthorDescription" class="text-danger"></span>
                    </div>
@*                     <div class="form-group">
                        @foreach (var category in ViewBag.Categories)
                        {
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="selectedCategoryIds" value="@category.Id"
                                @(Model.BookCategories.Select(bc => bc.CategoryId).Contains(category.Id) ? "checked" : "") />
                                <label class="form-check-label">@category.CategoryName</label>
                            </div>
                        }

                    </div> *@


                    <button type="submit" class="btn btn-primary">Add Book</button>
                </form>
            </div>
        </div>
    </div>
</div>
