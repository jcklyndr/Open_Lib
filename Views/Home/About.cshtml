@{
    ViewData["Title"] = "About Us";
}
<partial name="/Views/Shared/_Header.cshtml" />

<section class="py-5 bg-bubble-light">
    <div class="container py-4">
        <div class="row align-items-center g-5">

            <div class="col-lg-6 order-lg-2" data-aos="zoom-in" data-aos-duration="800">
                <div class="about-image-capsule rounded-5 shadow-lg"></div>
            </div>

            <div class="col-lg-6 order-lg-1" data-aos="fade-up" data-aos-duration="800">
                <div class="pe-lg-4 mt-4">
                    <span class="badge bg-info text-dark rounded-pill px-3 py-2 mb-3 fw-bold">Learn More</span>
                    <h2 class="display-5 fw-extrabold text-dark mb-4">Who Are We?</h2>
                    <p class="text-muted leading-relaxed mb-5">
                        <span class="fw-bold text-primary">Open Library</span> is a modern, centralized digital sanctuary built on the belief that knowledge and stories should be universally accessible. Our platform removes financial barriers, allowing readers from all walks of life to borrow, discover, and dive into thousands of books completely free of charge.
                    </p>

                    <div class="row g-4">

                        <div class="col-sm-6" data-aos="fade-up" data-aos-delay="100">
                            <div class="bg-white p-4 rounded-4 shadow-sm h-100 transition-bubble">
                                <div class="icon-bubble bg-primary text-white mb-3">
                                    <i class="fa-solid fa-bullseye"></i>
                                </div>
                                <h4 class="fw-bold text-dark fs-5">Our Mission</h4>
                                <p class="text-muted small mb-0">To democratize reading by providing an absolute free-to-read library ecosystem accessible anytime, anywhere.</p>
                            </div>
                        </div>

                        <div class="col-sm-6" data-aos="fade-up" data-aos-delay="200">
                            <div class="bg-white p-4 rounded-4 shadow-sm h-100 transition-bubble">
                                <div class="icon-bubble bg-warning text-white mb-3">
                                    <i class="fa-solid fa-eye"></i>
                                </div>
                                <h4 class="fw-bold text-dark fs-5">Our Vision</h4>
                                <p class="text-muted small mb-0">A world where financial status never restricts a mind from exploring global literature and academic resources.</p>
                            </div>
                        </div>

                        <div class="col-sm-6" data-aos="fade-up" data-aos-delay="300">
                            <div class="bg-white p-4 rounded-4 shadow-sm h-100 transition-bubble">
                                <div class="icon-bubble bg-secondary text-white mb-3">
                                    <i class="fa-solid fa-users"></i>
                                </div>
                                <h4 class="fw-bold text-dark fs-5">Beneficiaries</h4>
                                <p class="text-muted small mb-0">Students, passionate bookworms, and casual readers worldwide who seek unlimited zero-cost wisdom.</p>
                            </div>
                        </div>

                        <div class="col-sm-6" data-aos="fade-up" data-aos-delay="400">
                            <div class="bg-white p-4 rounded-4 shadow-sm h-100 transition-bubble">
                                <div class="icon-bubble bg-info text-dark mb-3">
                                    <i class="fa-solid fa-book-open-reader"></i>
                                </div>
                                <h4 class="fw-bold text-dark fs-5">100% Free Access</h4>
                                <p class="text-muted small mb-0">No hidden subscriptions, no paywalls, and no penalties. Just open, authentic knowledge at your fingertips.</p>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<partial name="/Views/Shared/_Footer.cshtml" />