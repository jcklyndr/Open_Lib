@{
    ViewData["Title"] = "Home Page";
}
<partial name="/Views/Shared/_Header.cshtml" />

<div class="hero-wrap text-white d-flex align-items-center justify-content-center position-relative overflow-hidden hero-bubble-bg" style="min-height: 75vh;">

    <div class="overlay position-absolute top-0 start-0 w-100 h-100 bg-black opacity-50"></div>

    <div class="container position-relative" style="z-index: 1;">
        <div class="row justify-content-center text-center">
            <div class="col-md-8" data-aos="fade-up" data-aos-duration="1000">
                <h2 class="subheading mb-2">
                    <span class="fs-4 fw-bold text-light text-uppercase tracking-wider">Welcome to Open Library</span>
                </h2>
                <h1 class="display-3 fw-extrabold mb-4 text-white">Find your favorite books!</h1>
                <div class="d-grid gap-2 d-sm-flex justify-content-sm-center mt-4">
                    <a href="@Url.Action("About", "Home")" class="btn btn-primary btn-lg px-4 me-sm-2 fw-bold rounded-pill shadow-sm transition-bubble border-0">Learn more</a>
                    <a href="@Url.Action("Contact", "Home")" class="btn btn-outline-light btn-lg px-4 fw-bold rounded-pill">Contact us</a>
                </div>
            </div>
        </div>
    </div>
</div>
<section class="py-5 bg-light customcategorycontainermain">
    <div class="container">
        <div class="text-center mb-5" data-aos="fade-up">
            <h2 class="fw-bold text-dark">Explore Our Categories</h2>
            <p class="text-muted">Discover books across your favorite genres</p>
        </div>

        <div class="row g-4">
            @foreach (var category in ViewBag.Categories as List<Category>)
            {
                var imageUrl = string.IsNullOrEmpty(category.Image)
                ? "/images/Sampleimg.png" 
                : category.Image;     

                <div class="col-md-4 col-sm-6 d-flex" data-aos="fade-up" data-aos-duration="800">
                    <div class="card h-100 w-100 shadow-sm border-0 transition-hover d-flex flex-column">

                        <div class="card-img"
                             style="background-image: url('@Url.Content(imageUrl)')">
                        </div>

                        <div class="card-body d-flex flex-column p-4">
                            <h3 class="card-title h5 fw-bold text-dark mb-2">@category.CategoryName</h3>
                            <p class="card-text text-muted text-justify mb-4 flex-grow-1">@category.Description</p>

                            <div class="mt-auto">
                                <a asp-controller="Books" asp-action="PerCategory" asp-route-categoryId="@category.Id" class="btn btn-primary w-100 fw-bold">
                                    <i class="fa-solid fa-book-open me-2"></i>View Books
                                </a>
                            </div>
                        </div>

                    </div>
                </div>
            }
        </div>
    </div>
</section>

<partial name="/Views/Shared/_Footer.cshtml" />